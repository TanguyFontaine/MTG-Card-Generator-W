# === Local development (individual DB vars) ===
DB_USER=your_local_db_user
DB_HOST=localhost
DB_NAME=your_local_db_name
DB_PASSWORD=your_local_db_password
DB_PORT=5432

# === Production (Neon connection string — overrides individual DB vars) ===
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# === CORS: deployed frontend URL (omit for local dev, defaults to http://localhost:3000) ===
# FRONTEND_URL=https://your-app.vercel.app

# === Port (Render sets this automatically, defaults to 3001 locally) ===
# PORT=3001
