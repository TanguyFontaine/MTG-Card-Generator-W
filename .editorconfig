# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 3

# TypeScript / JavaScript
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 3
quote_type = double

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# CSS
[*.css]
indent_style = space
indent_size = 3
